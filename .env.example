# FortiGate IPsec (IKEv1 + PSK + XAUTH) connection settings — primary gateway
VPN_HOST=vpn.example.com

# Phase-1 pre-shared key + XAUTH (extended auth) credentials
VPN_PSK=your_pre_shared_key
VPN_USER=your_username
VPN_PASS=your_password

# Phase-1 identity. Aggressive mode with the Local ID left empty on the
# FortiGate: keep VPN_LOCAL_ID empty (strongSwan identifies by IP).
VPN_LOCAL_ID=
VPN_AGGRESSIVE=yes

# Crypto proposals — matched to the FortiGate phase-1/phase-2 (DH group 14 =
# modp2048; the ESP group is the PFS group). AES256 and AES128 both offered.
VPN_IKE_PROPOSAL=aes256-sha256-modp2048,aes128-sha256-modp2048
VPN_ESP_PROPOSAL=aes256-sha256-modp2048,aes128-sha256-modp2048

# SA lifetimes, matched to the FortiGate key lifetimes.
VPN_IKE_LIFETIME=86400s
VPN_KEY_LIFETIME=43200s

# Subnets reachable through the tunnel. 0.0.0.0/0 = full tunnel, or a
# comma-separated list of the networks behind the FortiGate.
VPN_REMOTE_SUBNETS=0.0.0.0/0

# Secondary gateway for failover (optional; leave empty to disable). Same
# credentials/PSK/proposals are reused.
VPN_HOST2=

# Gateway/NAT: other containers reach the tunnel by adding a route via this
# container's static IP. Their forwarded traffic is SNAT'd onto the tunnel's
# virtual IP. Example, on the peer container:
#   ip route add 172.16.1.0/24 via 172.21.0.10
# Set NAT_ENABLED=false to disable forwarding/NAT.
NAT_ENABLED=true
# Source subnet whose forwarded traffic is routed over the tunnel (usually the
# shared docker network subnet).
VPN_PEER_SUBNET=172.21.0.0/16

# Watchdog settings
# PING_TARGET MUST be a host reachable THROUGH the tunnel that answers ICMP —
# the watchdog pings it from the tunnel's virtual IP. Point it at the remote
# host you actually depend on (e.g. the DB/API) so a broken route to it is
# detected. A host that never answers ICMP will flap the tunnel.
PING_TARGET=172.16.1.46
PING_INTERVAL=30
RECONNECT_WAIT=5
# Consecutive failed pings tolerated before reconnecting (a dropped SA still
# reconnects immediately).
HEALTH_FAIL_LIMIT=3
