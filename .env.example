# FortiClient SSL-VPN connection settings (primary gateway)
VPN_HOST=vpn.example.com
VPN_PORT=443
VPN_USER=your_username
VPN_PASS=your_password

# Optional: pin the server certificate (sha256 digest without the "sha256:" prefix)
VPN_TRUSTED_CERT=

# Secondary gateway for failover (optional; leave VPN_HOST2 empty to disable).
# Same VPN_USER/VPN_PASS are reused. VPN_PORT2 defaults to VPN_PORT if empty.
VPN_HOST2=
VPN_PORT2=
VPN_TRUSTED_CERT2=

# TCP forwards exposed to other containers on the shared network.
# Format: LOCAL_PORT:REMOTE_HOST:REMOTE_PORT (space-separated for multiple).
# Other containers then connect to forti-vpn:<LOCAL_PORT>.
# Example: expose the remote Postgres as forti-vpn:5432
FORWARDS=5432:10.20.0.15:5432

# Watchdog settings
# Tip: point PING_TARGET at the remote host you actually depend on (e.g. the DB)
# so the watchdog detects a broken route to it, not just a generic address.
PING_TARGET=10.20.0.15
PING_INTERVAL=30
RECONNECT_WAIT=5
